{
  "name": "bynd-contracts",
  "version": "1.0.0",
  "description": "BynD Protocol Smart Contracts — Mezo Matsnet",
  "scripts": {
    "compile":     "hardhat compile",
    "test":        "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:matsnet": "hardhat run scripts/deploy.ts --network matsnet",
    "node":        "hardhat node --fork https://rpc.test.mezo.org"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "hardhat": "^2.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "dotenv": "^16.4.0"
  }
}
