# Your matsnet deployer private key (never commit this)
DEPLOYER_PRIVATE_KEY=0x...

# Optional: override the default RPC if you're using a different provider
# (Boar, Validation Cloud, dRPC, etc). Defaults to https://rpc.test.mezo.org
MATSNET_RPC_URL=

# Optional overrides — these default to the addresses BynD v1 was deployed
# against on Matsnet. Only set these if you have reason to believe they've
# changed (e.g. Mezo redeployed ValidatorsVoter or RewardsDistributor).
VEMEZO_ADDRESS=
BOOST_VOTER_ADDRESS=
REWARDS_DISTRIBUTOR_ADDRESS=

# Optional: where the protocol fee / unfilled keeper bounty slots get paid.
# Defaults to the deployer address if unset. This is NOT the multisig
# transfer step — just where value flows during testnet deployment/testing.
TREASURY_ADDRESS=