{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "compile": {
      "inputs": ["contracts/**", "hardhat.config.ts"],
      "outputs": ["artifacts/**", "cache/**", "typechain-types/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "artifacts/**", "typechain-types/**"]
    },
    "test": {
      "dependsOn": ["compile"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
